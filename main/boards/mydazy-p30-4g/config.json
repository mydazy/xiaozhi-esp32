{
    "target": "esp32s3",
    "builds": [
        {
            "name": "mydazy-p30-4g",
            "sdkconfig_append": [
                "CONFIG_USE_DEVICE_AEC=y",
                "CONFIG_BOARD_TYPE_MYDAZY_P30_4G=y",
                "CONFIG_LV_DEF_REFR_PERIOD=20",
                "CONFIG_FLASH_DEFAULT_ASSETS=y",
                "CONFIG_USE_EMOTE_MESSAGE_STYLE=n",
                "CONFIG_LV_USE_LODEPNG=y",
                "CONFIG_LV_USE_GIF=y",
                "CONFIG_LV_GIF_CACHE_DECODE_DATA=y",
                "CONFIG_LV_USE_PNG=y",
                "CONFIG_LV_USE_QRCODE=y",
                "CONFIG_BT_ENABLED=y",
                "CONFIG_BT_NIMBLE_ENABLED=y",
                "CONFIG_BT_BLUEDROID_ENABLED=n",
                "CONFIG_BT_NIMBLE_BLUFI_ENABLE=y",
                "CONFIG_USE_HOTSPOT_WIFI_PROVISIONING=y",
                "CONFIG_USE_ESP_BLUFI_WIFI_PROVISIONING=y",
                "CONFIG_MBEDTLS_DHM_C=y",
                "CONFIG_SPIRAM=y",
                "CONFIG_SPIRAM_MODE_OCT=y",
                "CONFIG_ESP_SYSTEM_PANIC_PRINT_HALT=y",
                "CONFIG_EMOTE_DEF_LABEL_Y_OFFSET=45"
            ]
        }
    ]
}
